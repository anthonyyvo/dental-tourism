# Copy file này thành .env.local (file env chính) và điền giá trị thật
# .env.local được gitignore, không commit lên repo
#
# SMTP Gmail - Promotion Popup
# Bật 2FA và tạo App Password tại: https://myaccount.google.com/apppasswords
SMTP_USER=
SMTP_PASS=
PROMOTION_NOTIFY_EMAIL=

# CRM: lead API (server-only) — gửi kèm mỗi lần submit form contact & promotion
CRM_API_URL=
CRM_API_KEY=
